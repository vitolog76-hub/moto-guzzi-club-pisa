{
  "version": 2,
  "installCommand": "git clone https://github.com/flutter/flutter.git -b stable --depth 1 && ./flutter/bin/flutter precache && ./flutter/bin/flutter pub get",
  "buildCommand": "./flutter/bin/flutter build web --release",
  "outputDirectory": "build/web",
  "routes": [
    {
      "src": "/flutter_service_worker.js",
      "dest": "/flutter_service_worker.js",
      "headers": { "Cache-Control": "no-cache" }
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}